{
  "name": "@akshar5/relay",
  "version": "0.1.4",
  "private": true,
  "description": "A terminal workspace for carrying one coding task between Codex and OpenCode.",
  "keywords": [
    "cli",
    "codex",
    "coding-agent",
    "effect",
    "opencode",
    "tui"
  ],
  "homepage": "https://github.com/AksharP5/relay#readme",
  "bugs": {
    "url": "https://github.com/AksharP5/relay/issues"
  },
  "license": "MIT",
  "author": "Akshar Patel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AksharP5/relay.git"
  },
  "type": "module",
  "scripts": {
    "relay": "bun src/cli.ts",
    "build": "bun scripts/build.ts",
    "check": "bun run format:check && bun run typecheck && bun run test",
    "audit": "bun audit",
    "compat:latest": "bun scripts/compat-latest.ts",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "package:npm:launcher": "bun scripts/package-npm.ts launcher dist/npm/launcher",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && bun test ./test/relay-paths.bun.ts ./test/native-pty-host.bun.ts ./test/native-relay-host.bun.ts ./test/native-opencode-backend.bun.ts ./test/native-thread-store.bun.ts ./test/process-runner.bun.ts ./test/process-registry.bun.ts ./test/codex-app-server.bun.ts ./test/opencode-server.bun.ts ./test/settings.bun.ts ./test/thread-undo.bun.ts ./test/relay-service-transitions.bun.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.59",
    "effect": "4.0.0-beta.99",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "0.59.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@effect/platform-node-shared": "4.0.0-beta.59"
  },
  "packageManager": "bun@1.3.10"
}

{
  "name": "@aksharp5/relay",
  "version": "0.1.0",
  "description": "A terminal workspace for carrying one coding task between Codex and OpenCode.",
  "keywords": [
    "cli",
    "codex",
    "coding-agent",
    "effect",
    "opencode",
    "tui"
  ],
  "homepage": "https://github.com/AksharP5/relay#readme",
  "bugs": {
    "url": "https://github.com/AksharP5/relay/issues"
  },
  "license": "MIT",
  "author": "Akshar Patel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AksharP5/relay.git"
  },
  "bin": {
    "relay": "./dist/relay"
  },
  "files": [
    "dist/relay",
    "docs",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "relay": "bun src/cli.ts",
    "build": "bun scripts/build.ts",
    "check": "bun run format:check && bun run typecheck && bun run test",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && bun test ./test/tui.bun.tsx ./test/process-runner.bun.ts ./test/tui-controller.bun.ts ./test/codex-app-server.bun.ts ./test/opencode-server.bun.ts ./test/preference-store.bun.ts ./test/thread-undo.bun.ts",
    "test:watch": "vitest",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.59",
    "@opentui/core": "0.4.3",
    "@opentui/solid": "0.4.3",
    "effect": "4.0.0-beta.59",
    "picocolors": "^1.1.1",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "^0.27.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@effect/platform-node-shared": "4.0.0-beta.59"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.10"
}
